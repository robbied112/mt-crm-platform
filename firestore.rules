rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get the requesting user's profile
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() && getUserProfile().role == 'admin';
    }

    // Helper: check if user belongs to a specific tenant
    function isTenantMember(tenantId) {
      return isAuth() && (
        getUserProfile().tenantId == tenantId ||
        getUserProfile().territory == 'all' ||
        isAdmin()
      );
    }

    // Users collection: users can read/write their own profile, admins can manage all
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // Tenant config: only members of that tenant can read, only admins can write
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow write: if isAdmin();

      // Tenant data subcollections (uploaded data chunks)
      match /data/{fileType} {
        allow read: if isTenantMember(tenantId);
        allow write: if isAdmin();

        match /rows/{chunkId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isAdmin();
        }
      }

      // Upload audit logs
      match /uploadAudit/{auditId} {
        allow read: if isAdmin();
        allow write: if isTenantMember(tenantId);
      }

      // Invoices (written by Cloud Function via Admin SDK, readable by admins)
      match /invoices/{invoiceId} {
        allow read: if isAdmin();
        allow write: if false; // Only written by Cloud Function (Admin SDK)
      }

      // Account CRM data (tenant-scoped)
      match /accounts/{accountId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);

        match /notes/{noteId} {
          allow read, write: if isTenantMember(tenantId);
        }

        match /emails/{emailId} {
          allow read, write: if isTenantMember(tenantId);
        }

        match /files/{fileId} {
          allow read, write: if isTenantMember(tenantId);
        }
      }

      // Pipeline data (tenant-scoped)
      match /pipeline/{docId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);
      }

      // Pipeline activity log (tenant-scoped)
      match /pipeline_activity/{entryId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
