rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get the requesting user's profile
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() && getUserProfile().role == 'admin';
    }

    // Helper: check if user belongs to a specific tenant
    function isTenantMember(tenantId) {
      return isAuth() && getUserProfile().tenantId == tenantId;
    }

    // Helper: check if user is admin of a specific tenant
    function isTenantAdmin(tenantId) {
      return isAuth() && getUserProfile().role == 'admin' && getUserProfile().tenantId == tenantId;
    }

    // Helper: check if user is manager or admin of a specific tenant
    function isTenantManager(tenantId) {
      return isAuth() && getUserProfile().tenantId == tenantId
        && (getUserProfile().role == 'admin' || getUserProfile().role == 'manager');
    }

    // Helper: check if user can write CRM data (not a viewer)
    function canWriteCrm(tenantId) {
      return isTenantMember(tenantId) && getUserProfile().role != 'viewer';
    }

    // Users collection: users can read/write their own profile, tenant admins can manage their tenant's users
    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        (getUserProfile().role == 'admin' && getUserProfile().tenantId == resource.data.tenantId)
      );
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (
        request.auth.uid == userId ||
        (getUserProfile().role == 'admin' && getUserProfile().tenantId == resource.data.tenantId)
      );
      allow delete: if isAuth() && getUserProfile().role == 'admin' && getUserProfile().tenantId == resource.data.tenantId;
      // List: admin can only list users in their own tenant (query must filter by tenantId)
      allow list: if isAuth() && getUserProfile().role == 'admin'
        && resource.data.tenantId == getUserProfile().tenantId;
    }

    // Tenant config: only members of that tenant can read, only tenant admins can write.
    // SECURITY: subscription field is server-only (written by Stripe webhook + billing CFs via Admin SDK).
    // Client writes that modify the subscription field are blocked to prevent billing bypass.
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow create: if isTenantAdmin(tenantId);
      allow update: if isTenantAdmin(tenantId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);

      // Tenant config subcollection
      match /config/{doc} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Invite links — admins manage, validated server-side via Cloud Function
      match /invites/{inviteId} {
        allow read: if isTenantAdmin(tenantId);
        allow create: if isTenantAdmin(tenantId);
        allow delete: if isTenantAdmin(tenantId);
        // Updates (usedCount increment) happen server-side via Admin SDK
        allow update: if false;
      }

      // Tenant data subcollections — legacy pre-computed dashboards
      match /data/{fileType} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);

        match /rows/{chunkId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isTenantAdmin(tenantId);
        }
      }

      // Normalized model: raw imports (source of truth)
      match /imports/{importId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);

        match /rows/{chunkId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isTenantAdmin(tenantId);
        }
      }

      // Normalized model: pre-computed views (dashboards)
      match /views/{viewName} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);

        match /rows/{chunkId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isTenantAdmin(tenantId);
        }
      }

      // Pending account matches (AI dedup review queue)
      match /pendingMatches/{matchId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Wine entities (auto-extracted from billback imports)
      match /wines/{wineId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Pending wine matches (AI dedup review queue for wines)
      match /pendingWineMatches/{matchId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // AI Briefings — readable by tenant members, server writes via Admin SDK
      // Members can update the feedback field only (thumbs up/down)
      match /briefings/{briefingId} {
        allow read: if isTenantMember(tenantId);
        allow create: if false;
        allow delete: if false;
        allow update: if isTenantMember(tenantId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedback', 'feedbackAt']);

        // Actions — members can read, non-viewers can write (check/dismiss)
        match /actions/{actionId} {
          allow read: if isTenantMember(tenantId);
          allow write: if canWriteCrm(tenantId);
        }

        // Territory-scoped briefings — readable by members, writable by server only
        match /territories/{territoryName} {
          allow read: if isTenantMember(tenantId);
          allow write: if false;
        }
      }

      // Rate limits — server-managed
      match /rateLimits/{doc} {
        allow read, write: if false;
      }

      // Rebuild history — readable by tenant, writable by server only
      match /rebuildHistory/{doc} {
        allow read: if isTenantMember(tenantId);
        allow write: if false;
      }

      // Secrets — server-only (Cloud Functions via Admin SDK)
      match /secrets/{doc} {
        allow read, write: if false;
      }

      // Sync state and history — readable by tenant members, writable by server only
      match /syncState/{doc} {
        allow read: if isTenantMember(tenantId);
        allow write: if false;
      }

      match /syncHistory/{doc} {
        allow read: if isTenantMember(tenantId);
        allow write: if false;
      }

      // Learned column mappings (import config cache, non-viewers can write)
      match /learnedMappings/{mappingId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Import configuration cache (AI analysis cache, non-viewers can write)
      match /importConfigs/{configId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Upload logs
      match /uploads/{uploadId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Upload audit logs
      match /uploadAudit/{auditId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantMember(tenantId);
      }

      // Contacts scoped under tenant (viewers cannot write)
      match /contacts/{contactId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Tasks scoped under tenant (viewers cannot write)
      match /tasks/{taskId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Accounts scoped under tenant (viewers cannot write)
      match /accounts/{accountId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);

        match /notes/{noteId} {
          allow read: if isTenantMember(tenantId);
          allow write: if canWriteCrm(tenantId);
        }

        match /emails/{emailId} {
          allow read: if isTenantMember(tenantId);
          allow write: if canWriteCrm(tenantId);
        }

        match /files/{fileId} {
          allow read: if isTenantMember(tenantId);
          allow write: if canWriteCrm(tenantId);
        }
      }

      // Pipeline scoped under tenant (viewers cannot write)
      match /pipeline/{docId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Opportunities scoped under tenant (viewers cannot write)
      match /opportunities/{oppId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Products (wine catalog) scoped under tenant (viewers cannot write)
      match /products/{productId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Activity log scoped under tenant (viewers cannot write)
      match /activityLog/{logId} {
        allow read: if isTenantMember(tenantId);
        allow write: if canWriteCrm(tenantId);
      }

      // Analytics — tenant members can write events, admins can read
      match /analytics/{category}/{subcoll}/{eventId} {
        allow read: if isTenantAdmin(tenantId);
        allow create: if isTenantMember(tenantId);
      }
    }

    // Legacy top-level accounts (redirect reads only, for migration)
    match /accounts/{accountId} {
      allow read: if isAuth();
      allow write: if false;

      match /{subcoll}/{docId} {
        allow read: if isAuth();
        allow write: if false;
      }
    }

    // Legacy top-level pipeline (redirect reads only, for migration)
    match /pipeline/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
